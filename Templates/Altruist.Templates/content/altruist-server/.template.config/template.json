{
  "$schema": "http://json.schemastore.org/template",
  "author": "Aron Gere",
  "classifications": ["Game Server", "Real-Time", "Altruist"],
  "identity": "Altruist.Server.Template",
  "name": "Altruist Game Server",
  "shortName": "altruist",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "AltruistProject",
  "preferNameDirectory": true,
  "symbols": {
    "transport": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "tcp",
      "choices": [
        { "choice": "tcp", "description": "TCP with MessagePack" },
        { "choice": "websocket", "description": "WebSocket with JSON" },
        { "choice": "both", "description": "TCP + WebSocket" }
      ],
      "description": "Transport protocol"
    }
  }
}
